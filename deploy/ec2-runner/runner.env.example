# Copy to runner.env and fill in. runner.env is gitignored (holds secrets).
# setup.sh ships this to /etc/canopy-runner.env (chmod 600) on the box.

# --- canopy-web target + auth ---
CANOPY_BASE_URL=https://labs.connect.dimagi.com/canopy
# A canopy-web Personal Access Token (Bearer). Mint via the canopy plugin
# (/canopy:canopy-web-pat-mint) or `manage.py create_token`.
CANOPY_TOKEN=REPLACE_ME

# What this runner may execute — agent slugs and/or repo names. The harness
# claim only hands this runner turns whose target is in here.
RUNNER_CAPS={"projects":["canopy-web"]}
# Optional: pin a workspace slug (defaults to the token's default workspace).
RUNNER_WORKSPACE=
RUNNER_NAME=cloud-ec2-1

# --- claude auth ---
# The OAuth token `claude` authenticates with. Copy ace-web's current value, or
# mint a fresh ace@dimagi-ai.com token (claude setup-token) and paste it here.
CLAUDE_CODE_OAUTH_TOKEN=REPLACE_ME
