SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
DATABASE_URL=postgres://localhost:5432/canopy_web
ALLOWED_HOSTS=localhost,127.0.0.1

# AI Backend: "api" (direct Anthropic SDK) or "cli" (claude code CLI)
AI_BACKEND=api

# Required if AI_BACKEND=api
ANTHROPIC_API_KEY=sk-ant-your-key-here

# If AI_BACKEND=cli, the `claude` binary must be on PATH.
# No API key needed — uses Claude Code's own authentication.
